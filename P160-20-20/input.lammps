units           metal
boundary        p p p
atom_style      atomic

neighbor        1.0 bin

read_data	../relaxed.data
pair_style      deepmd ../PbI.pb 
pair_coeff      * * Pb I Cs C N H

thermo_style    custom step temp pe ke etotal press vol lx ly lz density spcpu
thermo          1000

timestep        0.00025

dump	3 all custom 1000 md.lammpstrj id type element x y z
dump_modify 3 element Pb I Cs C N H
fix     2 all nvt temp 300 300 $(100*dt)
run 	200000
unfix	2
undump	3